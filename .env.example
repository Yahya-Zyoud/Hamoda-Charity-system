# ─── MongoDB (used by docker-compose.dev.yml) ─────────────
MONGO_ROOT_USER=admin
MONGO_ROOT_PASS=changeme123
MONGO_DB=hamoda_charity

# ─── Backend ───────────────────────────────────────────────
# Backend reads its own .env from backend/.env (see backend/.env.example).
# Below are the values used by docker-compose.dev.yml at the root.
CORS_ORIGIN=http://localhost:5173
LOG_LEVEL=INFO

# ─── Frontend ──────────────────────────────────────────────
# Frontend reads .env.local from frontend/ (see frontend/.env.example).
VITE_API_URL=/api

# ─── Clerk (optional) ──────────────────────────────────────
# Get keys at https://dashboard.clerk.com — never commit real values.
VITE_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME
