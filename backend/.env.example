NODE_ENV=production
PORT=5000

# Your Vercel frontend URL — no trailing slash
CORS_ORIGIN=https://your-app.vercel.app

# MongoDB Atlas connection string
# Atlas dashboard → Connect → Drivers → copy the string, replace <password>
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/hamoda_charity?retryWrites=true&w=majority

# Clerk — backend secret key (Clerk dashboard → API Keys)
CLERK_SECRET_KEY=sk_live_...

# Stripe — secret key (optional, only needed for card payments)
STRIPE_SECRET_KEY=sk_live_...

# Used in Stripe success/cancel redirect URLs
FRONTEND_URL=https://your-app.vercel.app

