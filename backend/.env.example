NODE_ENV=development
PORT=5000
CORS_ORIGIN=http://localhost:5173

# MongoDB connection string (required for database features)
MONGO_URI=mongodb://localhost:27017/hamoda-charity

# JWT secret — CHANGE THIS in production to a long random string
JWT_SECRET=change_this_to_a_long_random_secret_in_production

# Clerk (optional — leave empty if not using Clerk auth)
# CLERK_SECRET_KEY=

# Log level: debug | info | warn | error
LOG_LEVEL=info
