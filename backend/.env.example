# Copy this file to .env and fill in real values. NEVER commit the real .env.
NODE_ENV=development
PORT=5000

# ── Network ───────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins, or "*" for any.
# Defaults to localhost:5173/5174/5175 when omitted.
CORS_ORIGIN=http://localhost:5173,http://localhost:5174
FRONTEND_URL=http://localhost:5173

# ── Database ──────────────────────────────────────────────────────────────
# Local MongoDB via docker compose (recommended for development):
MONGODB_URI=mongodb://root:rootsecret@localhost:27017/hamoda_charity?authSource=admin
# Production (Atlas):
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/hamoda_charity?retryWrites=true&w=majority

# ── Auth (Clerk) ──────────────────────────────────────────────────────────
# Required in production. When absent, protected routes return 401.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Set to "1" ONLY in development if you want to allow x-user-id header auth
# without real Clerk keys. Requires NODE_ENV != production. Off by default.
ALLOW_DEV_AUTH_BYPASS=0

# ── Payments (Stripe) ─────────────────────────────────────────────────────
# Without these, the donation form still works (donations are saved as
# pending and an admin can mark them completed manually).
STRIPE_SECRET_KEY=
# After deploying, run `stripe listen --forward-to /api/webhooks/stripe`
# and paste the signing secret here so payment confirmations work.
STRIPE_WEBHOOK_SECRET=

# ── Email (Resend) ────────────────────────────────────────────────────────
# Without this, emails are logged and skipped. Sign up at resend.com — the
# free tier covers 3,000 emails / month. EMAIL_FROM must be a verified
# sender on Resend (use the default sandbox until you verify a domain).
RESEND_API_KEY=
EMAIL_FROM=Hamoda Charity <onboarding@resend.dev>
