    "express": "^5.2.1",
    "express-rate-limit": "^8.5.1",
    "helmet": "^8.1.0",
    "mongodb": "^7.2.0",
    "mongoose": "^8.0.0",
    "multer": "^2.1.1",
    "openai": "^4.67.3",
    "pdfkit": "^0.18.0",
    "sanitize-html": "^2.17.4",
    "stripe": "^22.1.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "jest": "^30.4.2",
    "supertest": "^7.2.2"
  }
